<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileVerticalHorizontalApp.PopUp"
             Title="PopUp">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label
                Text="PopUp Leht "
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                x:Name="InfoLabel"
                Text="Vajuta nupule"
                FontSize="18"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Button
                Text="Küsi nime"
                Clicked="OnNameClicked" />

            <Button
                Text="Korrutustabeli test"
                Clicked="OnMathClicked" />

            <Button
                Text="Vali lehe värv"
                Clicked="OnColorClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>