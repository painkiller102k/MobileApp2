<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileVerticalHorizontalApp.MainPage"
             Title="MainPage">
    <VerticalStackLayout Spacing="20"
                         Padding="30"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">

        <Image Source="{Binding CurrentAnimalImage}"
               HeightRequest="200"
               WidthRequest="200" />

        <Button Text="Näita Põder"
                Clicked="OnPoderClicked" />

        <Button Text="Näita Orav"
                Clicked="OnOravClicked" />

        <Button Text="Näita Siil"
                Clicked="OnSiilClicked" />

    </VerticalStackLayout>
</ContentPage>